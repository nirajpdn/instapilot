{
  "name": "insta-pilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:all": "concurrently -k -n web,worker \"next dev\" \"tsx worker/index.ts\"",
    "build": "prisma generate && next build",
    "build:worker": "rm -rf dist-worker && tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json",
    "start:web": "next start",
    "start": "npm run build:worker && concurrently -k -n web,worker \"next start\" \"node dist-worker/worker/index.js\"",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "worker": "tsx worker/index.ts",
    "connect:export-session": "tsx scripts/export-instagram-session.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@radix-ui/react-slot": "^1.2.4",
    "avatar": "^0.1.0",
    "bullmq": "^5.43.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "dropdown-menu": "^0.1.1",
    "framer-motion": "^12.34.3",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.575.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "openai": "^4.86.1",
    "playwright": "^1.51.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.1.2",
    "prisma": "^6.4.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2"
  }
}
